<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Darts Merge Creator 2</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        body {
            background-color: #0f172a;
            color: #f8fafc;
            user-select: none;
        }
        .grid-cell {
            transition: transform 0.1s, box-shadow 0.1s;
        }
        .grid-cell:active {
            transform: scale(0.95);
        }
        .tool-btn {
            transition: all 0.2s;
        }
        .tool-btn.active {
            ring: 4px;
            transform: scale(1.1);
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
            z-index: 10;
        }
        
        /* Custom scrollbar for webkit */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #1e293b; 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb {
            background: #475569; 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #64748b; 
        }
    </style>
</head>
<body class="min-h-screen flex flex-col font-sans">

    <!-- Header -->
    <header class="bg-slate-900 border-b border-slate-700 py-4 px-6 shadow-lg flex flex-col sm:flex-row justify-between items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 to-purple-500">
                Darts Merge Creator 2
            </h1>
            <p class="text-slate-400 text-sm mt-1">Design your ultimate merge board</p>
        </div>

        <div class="flex flex-wrap items-center gap-4 bg-slate-800 p-3 rounded-xl border border-slate-700">
            <div class="flex items-center gap-2">
                <label for="cols" class="text-sm text-slate-300 font-medium">Cols:</label>
                <input type="number" id="cols" min="4" max="15" value="6" oninput="handleDimensionChange('cols')" class="w-16 bg-slate-700 border border-slate-600 rounded px-2 py-1 text-white focus:outline-none focus:border-cyan-500">
            </div>
            <button onclick="toggleRatioLock()" id="ratio-lock-btn" class="text-slate-400 hover:text-white transition-colors p-1" title="Lock A4 Ratio">
                <i id="ratio-lock-icon" class="ph ph-lock-key-open text-xl"></i>
            </button>
            <div class="flex items-center gap-2">
                <label for="rows" class="text-sm text-slate-300 font-medium">Rows:</label>
                <input type="number" id="rows" min="4" max="22" value="8" oninput="handleDimensionChange('rows')" class="w-16 bg-slate-700 border border-slate-600 rounded px-2 py-1 text-white focus:outline-none focus:border-cyan-500">
            </div>
            <button onclick="generateGrid()" class="bg-cyan-600 hover:bg-cyan-500 text-white px-4 py-1.5 rounded-lg font-semibold transition-colors flex items-center gap-2 shadow-lg shadow-cyan-500/20">
                <i class="ph ph-arrows-clockwise text-lg"></i> Rebuild Grid
            </button>
            <button onclick="clearGrid()" class="bg-red-600 hover:bg-red-500 text-white px-4 py-1.5 rounded-lg font-semibold transition-colors flex items-center gap-2 shadow-lg shadow-red-500/20">
                <i class="ph ph-trash text-lg"></i> Clear
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col lg:flex-row overflow-hidden">
        
        <!-- Grid Workspace Area -->
        <div class="flex-1 p-6 flex flex-col items-center justify-start overflow-auto bg-slate-950/50">
            <div class="bg-slate-800 p-3 rounded-2xl shadow-2xl border border-slate-700">
                <div id="grid-container" class="grid gap-1.5 mx-auto">
                    <!-- Grid cells will be injected here via JS -->
                </div>
            </div>
            
            <div class="mt-6 flex gap-4">
                <button onclick="exportJSON()" class="bg-slate-700 hover:bg-slate-600 px-6 py-2 rounded-lg font-medium transition flex items-center gap-2">
                    <i class="ph ph-export"></i> Export Level Data
                </button>
            </div>
            <textarea id="export-box" class="mt-4 w-full max-w-md h-24 bg-slate-900 border border-slate-700 rounded-lg p-3 text-xs font-mono text-slate-400 hidden" readonly></textarea>
        </div>

        <!-- Palettes Area -->
        <div class="w-full lg:w-96 bg-slate-900 border-t lg:border-t-0 lg:border-l border-slate-700 flex flex-col h-full lg:h-auto overflow-y-auto">
            
            <!-- Eraser Tool -->
            <div class="p-4 border-b border-slate-700 bg-slate-800/50">
                <button onclick="selectTool('eraser', null)" id="tool-eraser" class="tool-btn w-full bg-slate-700 hover:bg-slate-600 border border-slate-500 text-white py-3 rounded-xl font-bold flex items-center justify-center gap-2">
                    <i class="ph ph-eraser text-xl"></i> Eraser Tool
                </button>
            </div>

            <!-- Core Elements -->
            <div class="p-4 border-b border-slate-700">
                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Core Elements</h2>
                <div class="grid grid-cols-3 gap-2" id="palette-core">
                    <!-- Core tools injected here -->
                </div>
            </div>

            <!-- Numbers Palette -->
            <div class="p-4 border-b border-slate-700">
                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Number Tiles</h2>
                <div class="grid grid-cols-4 gap-2" id="palette-numbers">
                    <!-- Number buttons injected here -->
                </div>
            </div>

            <!-- Primary Life Lines -->
            <div class="p-4 border-b border-slate-700">
                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Primary Life Lines</h2>
                <div class="grid grid-cols-3 gap-2" id="palette-primary">
                    <!-- Primary tools injected here -->
                </div>
            </div>

            <!-- Secondary Life Lines -->
            <div class="p-4 border-b border-slate-700">
                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Secondary Life Lines</h2>
                <div class="grid grid-cols-3 gap-2" id="palette-secondary">
                    <!-- Secondary tools injected here -->
                </div>
            </div>

            <!-- Tertiary Life Lines -->
            <div class="p-4 mb-8">
                <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Tertiary Life Lines</h2>
                <div class="grid grid-cols-3 gap-2" id="palette-tertiary">
                    <!-- Tertiary tools injected here -->
                </div>
            </div>

        </div>
    </main>

    <script>
        // --- Configuration & Data ---
        const numberTiles = [2, 4, 8, 16, 32, 64, 128, 256, 512, 1024, 2048, 4096, 8192, 16384, 32768, 65536];
        
        const primaryTiles = [
            { id: 'bomb', name: 'Bombo', icon: 'ph-bomb', color: 'bg-rose-500 text-white border-rose-400' },
            { id: 'swap', name: 'Swap', icon: 'ph-arrows-left-right', color: 'bg-rose-600 text-white border-rose-500' },
            { id: 'hammer', name: 'Hammer', icon: 'ph-hammer', color: 'bg-rose-700 text-white border-rose-600' }
        ];

        const secondaryTiles = [
            { id: 'ad_break', name: 'Ad Break', icon: 'ph-monitor-play', color: 'bg-indigo-500 text-white border-indigo-400' },
            { id: 'expire_game', name: 'Expire', icon: 'ph-hourglass-high', color: 'bg-indigo-600 text-white border-indigo-500' },
            { id: 'remove_ads', name: 'No Ads', icon: 'ph-prohibit', color: 'bg-indigo-700 text-white border-indigo-600' }
        ];

        const tertiaryTiles = [
            { id: 'lucky_wheel', name: 'Wheel', icon: 'ph-aperture', color: 'bg-teal-500 text-white border-teal-400' },
            { id: 'extra_dart', name: 'Extra Dart', icon: 'ph-crosshair', color: 'bg-teal-600 text-white border-teal-500' },
            { id: 'entrance', name: 'Entrance', icon: 'ph-door-open', color: 'bg-teal-700 text-white border-teal-600' }
        ];

        const coreTiles = [
            { id: 'game_over', name: 'Game Over', icon: 'ph-skull', color: 'bg-zinc-950 text-red-500 border-red-800 shadow-[inset_0_0_15px_rgba(220,38,38,0.5)]' },
            { id: 'play_button', name: 'Play', icon: 'ph-play-circle', color: 'bg-emerald-500 text-white border-emerald-600' }
        ];

        // --- State ---
        let gridCols = 6;
        let gridRows = 8;
        let gridData = [];
        let activeTool = { category: 'number', value: 2 }; // Default tool
        let isDragging = false;
        let a4RatioLocked = false;
        const A4_RATIO = 1.4142;

        // --- Initialization ---
        function init() {
            renderPalettes();
            generateGrid();
            selectTool('number', 2);
            
            // Handle drag-to-paint mechanics
            document.addEventListener('mouseup', () => isDragging = false);
            document.addEventListener('touchend', () => isDragging = false);
        }

        // --- Core Functions ---
        function toggleRatioLock() {
            a4RatioLocked = !a4RatioLocked;
            const icon = document.getElementById('ratio-lock-icon');
            
            if (a4RatioLocked) {
                icon.className = 'ph ph-lock-key text-xl text-cyan-400';
                handleDimensionChange('cols'); // enforce immediately
            } else {
                icon.className = 'ph ph-lock-key-open text-xl';
            }
        }

        function handleDimensionChange(source) {
            if (!a4RatioLocked) return;
            
            let c = parseInt(document.getElementById('cols').value) || 4;
            let r = parseInt(document.getElementById('rows').value) || 4;
            
            if (source === 'cols') {
                r = Math.round(c * A4_RATIO);
                document.getElementById('rows').value = r;
            } else if (source === 'rows') {
                c = Math.round(r / A4_RATIO);
                document.getElementById('cols').value = c;
            }
        }

        function placeDefaultGameOver() {
            const midR = Math.floor(gridRows / 2);
            const midC = Math.floor(gridCols / 2);
            gridData[midR][midC] = { category: 'core', value: 'game_over' };
        }

        function generateGrid() {
            gridCols = parseInt(document.getElementById('cols').value) || 6;
            gridRows = parseInt(document.getElementById('rows').value) || 8;
            
            // Constrain
            if (gridCols < 4) gridCols = 4; if (gridCols > 15) gridCols = 15;
            if (gridRows < 4) gridRows = 4; if (gridRows > 22) gridRows = 22;
            
            document.getElementById('cols').value = gridCols;
            document.getElementById('rows').value = gridRows;

            gridData = Array(gridRows).fill(null).map(() => Array(gridCols).fill(null));
            placeDefaultGameOver();
            renderGrid();
            document.getElementById('export-box').classList.add('hidden');
        }

        function clearGrid() {
            if(confirm("Are you sure you want to clear the entire grid?")) {
                gridData = Array(gridRows).fill(null).map(() => Array(gridCols).fill(null));
                placeDefaultGameOver();
                renderGrid();
                document.getElementById('export-box').classList.add('hidden');
            }
        }

        function renderGrid() {
            const container = document.getElementById('grid-container');
            container.innerHTML = '';
            
            // Set dynamic grid layout based on columns
            container.style.gridTemplateColumns = `repeat(${gridCols}, minmax(0, 1fr))`;
            
            // Determine a responsive cell size class based on grid dimensions to prevent overflow
            let cellSizeClass = "w-12 h-12 sm:w-14 sm:h-14 lg:w-16 lg:h-16 text-xl";
            if (gridCols > 8 || gridRows > 10) cellSizeClass = "w-10 h-10 sm:w-12 sm:h-12 text-sm";
            if (gridCols > 12) cellSizeClass = "w-8 h-8 sm:w-10 sm:h-10 text-xs";

            for (let r = 0; r < gridRows; r++) {
                for (let c = 0; c < gridCols; c++) {
                    const cell = document.createElement('div');
                    cell.className = `grid-cell rounded-lg cursor-pointer flex items-center justify-center font-bold border-2 transition-colors duration-150 select-none ${cellSizeClass} shadow-inner`;
                    
                    const cellData = gridData[r][c];
                    
                    if (!cellData) {
                        cell.classList.add('bg-slate-700', 'border-slate-600', 'hover:bg-slate-600');
                    } else {
                        applyCellVisuals(cell, cellData);
                    }

                    // Painting Events
                    cell.addEventListener('mousedown', (e) => {
                        e.preventDefault(); // Prevent text selection
                        isDragging = true;
                        paintCell(r, c);
                    });
                    cell.addEventListener('mouseenter', () => {
                        if (isDragging) paintCell(r, c);
                    });
                    
                    // Touch events for mobile painting
                    cell.addEventListener('touchstart', (e) => {
                        e.preventDefault();
                        isDragging = true;
                        paintCell(r, c);
                    });
                    cell.addEventListener('touchmove', (e) => {
                        e.preventDefault();
                        if (!isDragging) return;
                        const touch = e.touches[0];
                        const target = document.elementFromPoint(touch.clientX, touch.clientY);
                        if (target && target.classList.contains('grid-cell')) {
                            // Find row and col from DOM (hacky but works for quick touch painting)
                            const index = Array.from(container.children).indexOf(target);
                            if (index !== -1) {
                                const tr = Math.floor(index / gridCols);
                                const tc = index % gridCols;
                                paintCell(tr, tc);
                            }
                        }
                    });

                    container.appendChild(cell);
                }
            }
        }

        function paintCell(r, c) {
            const currentCell = gridData[r][c];

            // Check if removing a game_over tile
            const isTargetGameOver = currentCell && currentCell.value === 'game_over';
            const isPlacingGameOver = activeTool.value === 'game_over';

            if (isTargetGameOver && !isPlacingGameOver) {
                // Count existing game_over tiles
                let gameOverCount = 0;
                for (let i = 0; i < gridRows; i++) {
                    for (let j = 0; j < gridCols; j++) {
                        if (gridData[i][j] && gridData[i][j].value === 'game_over') {
                            gameOverCount++;
                        }
                    }
                }
                
                // Prevent removing the last Game Over tile
                if (gameOverCount <= 1) {
                    return; // Cannot remove the last one
                }
            }

            if (activeTool.category === 'eraser') {
                gridData[r][c] = null;
            } else {
                gridData[r][c] = { category: activeTool.category, value: activeTool.value };
            }
            renderGrid();
        }

        // --- Visual Mapping ---
        function getNumberColors(val) {
            const colors = {
                2: 'bg-[#eee4da] text-[#776e65] border-[#dacaba]',
                4: 'bg-[#ede0c8] text-[#776e65] border-[#e0cba8]',
                8: 'bg-[#f2b179] text-white border-[#e6985b]',
                16: 'bg-[#f59563] text-white border-[#df7a47]',
                32: 'bg-[#f67c5f] text-white border-[#de6042]',
                64: 'bg-[#f65e3b] text-white border-[#df4320]',
                128: 'bg-[#edcf72] text-white border-[#ddbd53]',
                256: 'bg-[#edcc61] text-white border-[#ddb945]',
                512: 'bg-[#edc850] text-white border-[#dcb638]',
                1024: 'bg-[#edc53f] text-white border-[#dcb028]',
                2048: 'bg-[#edc22e] text-white border-[#d9ab18]',
                4096: 'bg-[#3c3a32] text-[#f9f6f2] border-[#201f1b]',
                8192: 'bg-[#3c3a32] text-[#f9f6f2] border-[#201f1b]',
                16384: 'bg-[#3c3a32] text-[#f9f6f2] border-[#201f1b]',
                32768: 'bg-[#3c3a32] text-[#f9f6f2] border-[#201f1b]',
                65536: 'bg-[#3c3a32] text-[#f9f6f2] border-[#201f1b]'
            };
            return colors[val] || 'bg-gray-800 text-white border-gray-900';
        }

        function getSpecialTileData(category, id) {
            if (category === 'core') return coreTiles.find(t => t.id === id);
            if (category === 'primary') return primaryTiles.find(t => t.id === id);
            if (category === 'secondary') return secondaryTiles.find(t => t.id === id);
            if (category === 'tertiary') return tertiaryTiles.find(t => t.id === id);
            return null;
        }

        function applyCellVisuals(element, data) {
            if (data.category === 'number') {
                element.className += ' ' + getNumberColors(data.value);
                
                // Adjust text size for large numbers
                if(data.value > 1000) {
                    element.innerHTML = `<span class="text-[0.65em]">${data.value}</span>`;
                } else {
                    element.innerHTML = `<span>${data.value}</span>`;
                }
            } else {
                const specData = getSpecialTileData(data.category, data.value);
                if (specData) {
                    element.className += ' ' + specData.color;
                    element.innerHTML = `<i class="ph ${specData.icon} text-2xl"></i>`;
                }
            }
        }

        // --- Palettes & Tools ---
        function selectTool(category, value) {
            activeTool = { category, value };
            
            // UI Update for active tool
            document.querySelectorAll('.tool-btn').forEach(btn => {
                btn.classList.remove('ring-4', 'ring-cyan-400', 'scale-110', 'active');
            });
            
            const btnId = category === 'eraser' ? 'tool-eraser' : `tool-${category}-${value}`;
            const activeBtn = document.getElementById(btnId);
            if(activeBtn) {
                activeBtn.classList.add('ring-4', 'ring-cyan-400', 'scale-110', 'active');
            }
        }

        function renderPalettes() {
            // Numbers
            const numContainer = document.getElementById('palette-numbers');
            numberTiles.forEach(num => {
                const btn = document.createElement('button');
                btn.id = `tool-number-${num}`;
                btn.className = `tool-btn aspect-square rounded-xl font-bold text-sm sm:text-base border-2 shadow flex items-center justify-center ${getNumberColors(num)}`;
                
                if(num > 1000) btn.innerHTML = `<span class="text-xs sm:text-sm">${num}</span>`;
                else btn.textContent = num;

                btn.onclick = () => selectTool('number', num);
                numContainer.appendChild(btn);
            });

            // Special Tools Renderer
            const renderSpecial = (items, containerId, category) => {
                const container = document.getElementById(containerId);
                items.forEach(item => {
                    const btn = document.createElement('button');
                    btn.id = `tool-${category}-${item.id}`;
                    btn.className = `tool-btn aspect-square rounded-xl flex flex-col items-center justify-center gap-1 border-2 shadow p-1 ${item.color}`;
                    btn.innerHTML = `
                        <i class="ph ${item.icon} text-2xl"></i>
                        <span class="text-[0.6rem] font-bold leading-tight uppercase text-center">${item.name}</span>
                    `;
                    btn.onclick = () => selectTool(category, item.id);
                    container.appendChild(btn);
                });
            }

            renderSpecial(coreTiles, 'palette-core', 'core');
            renderSpecial(primaryTiles, 'palette-primary', 'primary');
            renderSpecial(secondaryTiles, 'palette-secondary', 'secondary');
            renderSpecial(tertiaryTiles, 'palette-tertiary', 'tertiary');
        }

        // --- Export Feature ---
        function exportJSON() {
            const exportData = {
                game: "Darts Merge Creator 2",
                dimensions: { cols: gridCols, rows: gridRows },
                grid: gridData
            };
            const box = document.getElementById('export-box');
            box.value = JSON.stringify(exportData, null, 2);
            box.classList.remove('hidden');
            box.select();
            
            // Attempt to copy
            try {
                document.execCommand('copy');
                alert('Level data exported and copied to clipboard!');
            } catch (err) {
                alert('Level data generated. Please copy it from the text box below the grid.');
            }
        }

        // Run
        window.onload = init;
    </script>
</body>
</html>




